# ==== core ====
# JWT_SECRET nao tem default, app falha no boot se faltar
JWT_SECRET=change-me-use-openssl-rand-hex-32
DATABASE_URL=postgresql+asyncpg://up2gether:up2gether@localhost:5432/up2gether

# ==== dev only — NUNCA ligar em prod ====
# habilita POST /api/auth/dev-login pra E2E (mint JWT direto sem Discord)
DEV_LOGIN_ENABLED=false

# ==== cors ====
CORS_ORIGINS=["http://localhost:5173"]

# ==== discord ====
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:5173/auth/discord/callback

# ==== steam ====
STEAM_API_KEY=
